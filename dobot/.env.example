# ─────────────────────────────────────────────────────────────
#  Salin file ini menjadi  .env  lalu sesuaikan nilainya.
#      cp .env.example .env        (Linux/Mac)
#      copy .env.example .env      (Windows)
#  Semua nilai di bawah WAJIB terisi — aplikasi tidak akan
#  memakai angka default tersembunyi.
# ─────────────────────────────────────────────────────────────

# ── SERVER (alamat web dashboard) ───────────────────────────
HOST=0.0.0.0
PORT=5001

# ── ROBOT (Dobot Nova 5) ────────────────────────────────────
# Ganti DOBOT_IP dengan IP robot di jaringan kamu.
DOBOT_IP=192.168.x.x
DOBOT_DASHBOARD_PORT=29999
DOBOT_MOVE_PORT=30003
DOBOT_PRESETS_JSON=config/new_preset.json

# Waktu tunggu maksimum (detik) saat mengaktifkan robot sebelum lanjut.
ROBOT_ENABLE_TIMEOUT=15.0

# Kecepatan & akselerasi gerak (skala 1–100).
ROBOT_SPEED_FACTOR=100
ROBOT_JOINT_SPEED=80
ROBOT_JOINT_ACC=30

# ── CAMERA (input webcam untuk MediaPipe) ───────────────────
# CAMERA_INDEX: 0 = webcam utama, 1 = webcam kedua, dst.
CAMERA_INDEX=0
CAMERA_SOURCE=laptop
FRAME_WIDTH=640
FRAME_HEIGHT=480
JPEG_QUALITY=75

# ── MEDIAPIPE (pengenalan gesture tangan) ───────────────────
MP_MODEL_PATH=model/hand_gesture_recognizer_v3
MP_MAX_HANDS=1
MP_DETECTION_CONF=0.4
MP_TRACKING_CONF=0.4

# ── RUNTIME BEHAVIOR (pengaturan alur kerja) ────────────────
PRESET_DEBOUNCE_FRAMES=30
SAFETY_HOLD_SEC=1.5
SAFETY_TIMEOUT=10.0
POST_ACTION_DELAY=0.5
COOLDOWN_AFTER_CAPTURE=5.5

# ── BACKEND (notifikasi mulai/selesai gerak) ────────────────
# Isi dengan URL backend kamu sendiri.
BACKEND_URL=http://localhost:8080
