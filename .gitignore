# ─── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/
*.iml

# ─── Environment files (NEVER commit secrets) ────────────────────────────────
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# ─── Node / Next.js ──────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.turbo/
frontend/.cache/
frontend/coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Go build artifacts ──────────────────────────────────────────────────────
backend/bin/
backend/*.exe
backend/**/*.exe
backend/*.test
backend/*.out
backend/photobooth
backend/photobooth.exe

# ─── Backend runtime data (per-session uploads/processing) ───────────────────
# storage/sessions/ adalah hasil capture per session — ignore semua isinya
# tapi keep folder tetap ada via .gitkeep
backend/storage/sessions/
backend/storage/*.db
backend/storage/**/*.db
backend/storage/tmp/

# Frame & package: upload admin saat runtime (nama uuid) JANGAN di-commit.
# Seed default (frame-164..167.svg, digital.svg, print.svg) tetap di-track via
# pengecualian "!" di bawah. File seed baru → tambahkan "!"-nya atau `git add -f`.
backend/storage/frames/*
!backend/storage/frames/frame-164.svg
!backend/storage/frames/frame-165.svg
!backend/storage/frames/frame-166.svg
!backend/storage/frames/frame-167.svg
backend/storage/packages/*
!backend/storage/packages/digital.svg
!backend/storage/packages/print.svg

# ─── Generic logs ────────────────────────────────────────────────────────────
*.log

# ─── Tooling ─────────────────────────────────────────────────────────────────
# Claude Code skills cache (auto-regenerated)
frontend/skills-lock.json
skills-lock.json

# Claude Code local settings (user-specific overrides, never commit).
# Shared config (.claude/settings.json) tetap bisa di-track kalau ada.
.claude/settings.local.json
.claude/cache/
.claude/logs/

# ─── Kredensial Google Drive (defensif — JANGAN commit) ──────────────────────
# Integrasi pakai env (GOOGLE_*), tapi cegah kalau ada yang pakai file kredensial.
credentials.json
*credentials*.json
token.json
gdrive-token.json
service-account*.json

# ─── Deployment / Misc ───────────────────────────────────────────────────────
.vercel/
*.pem
