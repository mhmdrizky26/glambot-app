# ─── OS / Editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/
*.iml

# ─── Environment files (NEVER commit secrets) ────────────────────────────────
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example

# ─── Node / Next.js ──────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.turbo/
frontend/.cache/
frontend/coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Go build artifacts ──────────────────────────────────────────────────────
backend/bin/
backend/*.exe
backend/**/*.exe
backend/*.test
backend/*.out
backend/photobooth
backend/photobooth.exe

# ─── Python / dobot (robot gesture-control service) ──────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
dobot/venv/
dobot/lua/
dobot/testcamera.py

# ─── Backend runtime data (per-session uploads/processing) ───────────────────
# storage/sessions/ adalah hasil capture per session — ignore semua isinya
# tapi keep folder tetap ada via .gitkeep
backend/storage/sessions/
backend/storage/*.db
backend/storage/**/*.db
backend/storage/tmp/

# Frame & package: upload admin saat runtime (nama uuid) JANGAN di-commit.
# Seed default (frame-164..167.svg, digital.svg, print.svg) tetap di-track via
# pengecualian "!" di bawah. File seed baru → tambahkan "!"-nya atau `git add -f`.
backend/storage/frames/*
!backend/storage/frames/frame-164.svg
!backend/storage/frames/frame-165.svg
!backend/storage/frames/frame-166.svg
!backend/storage/frames/frame-167.svg
# frame-165 vector murni: overlay PNG hasil render (alpha asli) dipakai GIF live
# agar dekorasi yang menjuntai ke window (lanteran) tidak tertutup burst.
!backend/storage/frames/frame-165.png
# Frame custom hasil upload admin (dipin agar identik saat clone di device lain).
# Metadata slot/canvas-nya ada di backend/migrations/seed_frames.sql (UPSERT).
# Tambah frame baru → daftarkan filenya di sini + regenerate seed_frames.sql.
!backend/storage/frames/0466cff5-0edc-4f01-af7f-e4fab0686a03.png
!backend/storage/frames/1a7e8ae6-9485-450a-8e7d-f195819d0185.png
!backend/storage/frames/1b691551-b1b1-43e4-babd-b616085fe96e.png
!backend/storage/frames/2613d174-7c9f-40d8-9197-02b9f849c9e3.png
!backend/storage/frames/29b28eeb-6294-43af-a22e-fcbd2aed939f.png
!backend/storage/frames/3d3c91d3-4949-432c-a80b-a125ca3c4ad2.png
!backend/storage/frames/513bf6e4-d70b-4b2e-8332-34c35b426e5f.png
!backend/storage/frames/64b7faf6-fc00-42fa-b4b2-c77e974ece92.png
!backend/storage/frames/8b42ae9d-9b89-4ae8-8be8-a2764029a4da.png
!backend/storage/frames/9386ba48-4eb8-49f3-b7b9-ee19fd1f9998.png
!backend/storage/frames/ae168b1a-fa98-4a3b-be48-e11148b3a7d4.png
!backend/storage/frames/d26d6ea4-831b-4528-9877-5551fe5a987b.png
