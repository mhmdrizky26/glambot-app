# ─── Generic logs ────────────────────────────────────────────────────────────
*.log

# ─── Tooling ─────────────────────────────────────────────────────────────────
# Claude Code skills cache (auto-regenerated)
frontend/skills-lock.json
skills-lock.json

# Claude Code local settings (user-specific overrides, never commit).
# Shared config (.claude/settings.json) tetap bisa di-track kalau ada.
.claude/settings.local.json
.claude/cache/
.claude/logs/

# ─── Kredensial Google Drive (defensif — JANGAN commit) ──────────────────────
# Integrasi pakai env (GOOGLE_*), tapi cegah kalau ada yang pakai file kredensial.
credentials.json
*credentials*.json
token.json
gdrive-token.json
service-account*.json

# ─── Deployment / Misc ───────────────────────────────────────────────────────
.vercel/
*.pem
