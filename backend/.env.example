APP_PORT=8080
APP_ENV=development

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/photobooth?sslmode=disable

# Midtrans (optional for local dev; payment feature depends on this)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_ENV=sandbox

# Paths and app behavior
STORAGE_PATH=./storage
DIGICAM_BASE_URL=http://localhost:5513/api
SESSION_EXPIRY_HOURS=72
CLEANUP_INTERVAL_HOURS=24

# Frontend URL used by CORS check
FRONTEND_URL=http://localhost:3000

# Camera: Canon-only via digiCamControl (lihat DIGICAM_BASE_URL di atas).
# Live preview & capture diambil dari digiCamControl; tidak ada lagi mode
# webcam laptop (builtin).

# Robot integration (optional)
ROBOT_API_URL=
ROBOT_ENABLED=false

# Google Drive upload (optional) — upload hasil tiap sesi ke Drive lalu QR di
# halaman download mengarah ke folder publiknya. Kosongkan untuk menonaktifkan.
# Cara: buat OAuth Client ID "Web application" di Google Cloud Console,
# tambahkan redirect URI http://localhost:8090/callback, isi 2 baris di bawah,
# lalu jalankan `go run ./cmd/gdrive-token` untuk mendapatkan refresh token.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Opsional: ID folder induk di Drive (kosong = root My Drive).
GOOGLE_DRIVE_FOLDER_ID=
