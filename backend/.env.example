APP_PORT=8080
APP_ENV=development

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/photobooth?sslmode=disable

# Midtrans (optional for local dev; payment feature depends on this)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_ENV=sandbox

# Paths and app behavior
STORAGE_PATH=./storage
DIGICAM_BASE_URL=http://localhost:5513/api
SESSION_EXPIRY_HOURS=72
CLEANUP_INTERVAL_HOURS=24

# Frontend URL used by CORS check
FRONTEND_URL=http://localhost:3000

# Camera configuration
# Set to true to force using laptop camera (builtin) instead of Canon for testing
USE_BUILTIN_CAMERA=false

# Robot integration (optional)
ROBOT_API_URL=
ROBOT_ENABLED=false
